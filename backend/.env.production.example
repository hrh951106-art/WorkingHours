# 生产环境配置示例文件
# 使用方法: cp .env.production.example .env.production

# ==================== 数据库配置 ====================
# PostgreSQL数据库连接字符串
# 格式: postgresql://用户名:密码@主机:端口/数据库名?schema=架构名
DATABASE_URL="postgresql://jy_user:your_password@localhost:5432/jy_production?schema=public"

# 如果使用远程数据库或云数据库:
# DATABASE_URL="postgresql://user:password@production-db.example.com:5432/jy_db?schema=public"

# 如果使用连接池（推荐生产环境）:
# DATABASE_URL="postgresql://user:password@host:port/db?pgbouncer=true&connection_limit=10"

# ==================== JWT配置 ====================
# JWT密钥（生产环境必须使用强随机密钥）
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"
JWT_EXPIRES_IN="7d"

# ==================== 服务器配置 ====================
PORT=3000
NODE_ENV="production"

# ==================== CORS配置 ====================
# 允许的前端域名（多个用逗号分隔）
ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"

# ==================== API配置 ====================
API_BASE_URL="https://your-domain.com/api"
FRONTEND_URL="https://your-domain.com"

# ==================== 日志配置 ====================
LOG_LEVEL="info"
LOG_FILE_PATH="/var/log/jy-backend"

# ==================== 文件上传配置 ====================
MAX_FILE_SIZE=10485760
UPLOAD_DIR="/var/uploads/jy"

# ==================== 邮件配置（可选）====================
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="noreply@your-domain.com"
SMTP_PASSWORD="your-email-password"
EMAIL_FROM="JY系统 <noreply@your-domain.com>"

# ==================== Redis配置（可选，用于缓存）====================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# ==================== 性能配置 ====================
# 数据库连接池大小
DB_POOL_MIN=2
DB_POOL_MAX=10

# 请求超时时间（毫秒）
REQUEST_TIMEOUT=30000

# ==================== 安全配置 ====================
# 限流配置
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# Session配置
SESSION_SECRET="another-random-secret-key-for-sessions"
SESSION_MAX_AGE=604800000
