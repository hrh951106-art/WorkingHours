{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": [
      {
        "name": "@nestjs/swagger",
        "options": {
          "classValidatorShim": true,
          "controllerKey": "swagger",
          "dtoKeyOfComment": "description",
          "dtoKeyOfValue": "description",
          "controllerKeyOfComment": "description",
          "dtoKeyOfTag": "description",
          "controllerKeyOfTag": "description"
        }
      }
    ]
  }
}
