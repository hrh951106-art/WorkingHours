  createdById           Int
  createdByName         String
  createdAt             DateTime                 @default(now())
  updatedById           Int?
  updatedByName         String?
  updatedAt             DateTime                 @updatedAt

  @@unique([employeeNo, coefficientType, effectiveDate])
  @@index([employeeNo])
  @@index([coefficientType])
  @@index([effectiveDate])
}

// ============ Product Standard Hour By Level 模块 ============

model ProductStandardHourByLevel {
  id                    Int                      @id @default(autoincrement())
  productId             Int
  productName           String
  accountLevel          String
  accountPath           String?
  standardHours         Float
  quantity              Float?
  effectiveDate         DateTime
  expiryDate            DateTime?
  status                String                   @default("ACTIVE")
  description           String?
  createdById           Int
  createdByName         String
  createdAt             DateTime                 @default(now())
  deletedAt             DateTime?

  @@index([productId, effectiveDate, expiryDate, status])
  @@index([accountLevel])
}

// ============ Work Hour Result 模块 ============

model WorkHourResult {
  id                    Int                      @id @default(autoincrement())
  employeeNo            String
  employeeId            Int?
  workDate              DateTime
  calcDate              DateTime?
  shiftId               Int?
  shiftName             String?
  attendanceCodeId      Int?
  attendanceCode        String?
  calcAttendanceCode    String?
  attendanceCodeName    String?
  workHours             Float                    @default(0)
  amount                Float?
  calculateAmount       Float?
  accountId             Int?
  accountName           String?
  accountPath           String?
  sourceType            String?
  sourceId              Int?
  source                String?
  sourceBatchId         String?
  attendancePunchPair   Int?
  customFields          String                   @default("{}")
  orgId                 Int?
  definitionAttendanceCodeId Int?
  definitionAttendanceCodeStr String?
  startTime             DateTime?
  endTime               DateTime?
  status                String                   @default("PENDING")
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  definitionAttendanceCode DefinitionAttendanceCode? @relation(fields: [definitionAttendanceCodeId], references: [id])

  @@index([employeeNo, workDate])
  @@index([workDate])
  @@index([calcDate])
  @@index([accountId])
  @@index([status])
  @@index([employeeId])
  @@index([orgId])
}

// ============ Allocation Work Hour 模块 ============

model AllocationWorkHour {
  id                    Int                      @id @default(autoincrement())
  batchNo               String
  recordDate            DateTime
  configId              Int
  sourceEmployeeNo      String?
  sourceEmployeeName    String?
  sourceAccountId       Int?
  sourceAccountName     String?
  attendanceCodeId      Int?
  attendanceCode        String?
  definitionAttendanceCodeId Int?
  sourceHours           Float
  targetType            String
  targetId              Int
  targetName            String
  targetAccountId       Int?
  allocatedHours        Float
  calcTime              DateTime
  createdAt             DateTime                 @default(now())
  deletedAt             DateTime?

  @@index([batchNo])
  @@index([recordDate])
  @@index([configId])
  @@index([sourceEmployeeNo])
  @@index([calcTime])
  @@index([deletedAt])
  @@index([definitionAttendanceCodeId])
}

// ============ BI Report 模块相关模型 ============

model BiReport {
  id                    Int                      @id @default(autoincrement())
  code                  String                   @unique
  name                  String
  description           String?
  category              String?
  modelId               Int?
  status                String                   @default("ACTIVE")
  createdById           Int
  createdByName         String
  createdAt             DateTime                 @default(now())
  updatedById           Int?
  updatedByName         String?
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  model                 ReportDataModel?         @relation(fields: [modelId], references: [id])
  widgets               BiReportWidget[]
  parameters            BiReportParameter[]
  accessLogs            BiReportAccessLog[]

  @@index([status])
  @@index([category])
  @@index([deletedAt])
  @@index([modelId])
}

model BiReportWidget {
  id                    Int                      @id @default(autoincrement())
  reportId              Int
  code                  String
  name                  String
  description           String?
  type                  String?
  title                 String?
  widgetType            String
  dataSource            String
  config                String                   @default("{}")
  queryConfig           String?                  @default("{}")
  style                 String?                  @default("{}")
  position              String                   @default("{}")
  status                String                   @default("ACTIVE")
  sortOrder             Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  report                BiReport                 @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([deletedAt])
}

model BiReportParameter {
  id                    Int                      @id @default(autoincrement())
  reportId              Int
  code                  String
  name                  String
  description           String?
  parameterType         String
  defaultValue          String?
  required              Boolean                  @default(false)
  config                String                   @default("{}")
  status                String                   @default("ACTIVE")
  sortOrder             Int                      @default(0)
  sortNo                Int?                     @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  report                BiReport                 @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([status])
  @@index([deletedAt])
}

model BiReportAccessLog {
  id                    Int                      @id @default(autoincrement())
  reportId              Int
  userId                Int
  userName              String?
  accessType            String
  accessTime            DateTime                 @default(now())
  ipAddress             String?
  userAgent             String?
  report                BiReport                 @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([reportId])
  @@index([userId])
  @@index([accessTime])
}

model ReportDataModel {
  id                    Int                      @id @default(autoincrement())
  code                  String                   @unique
  name                  String
  description           String?
  category              String?
  type                  String?
  dataSource            String?
  sourceTable           String?
  sourceSql             String?
  status                String                   @default("ACTIVE")
  createdById           Int
  createdByName         String
  createdAt             DateTime                 @default(now())
  updatedById           Int?
  updatedByName         String?
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  reports               BiReport[]
  fields                ReportModelField[]
  relations             ReportModelRelation[]

  @@index([status])
  @@index([category])
  @@index([deletedAt])
}

model ReportModelField {
  id                    Int                      @id @default(autoincrement())
  modelId               Int
  code                  String
  name                  String
  description           String?
  fieldType             String
  dataType              String?
  sourceExpr            String?
  aggregation           String?
  sourceTable           String?
  type                  String?
  dataSource            String?
  config                String                   @default("{}")
  status                String                   @default("ACTIVE")
  sortOrder             Int                      @default(0)
  sortNo                Int?                     @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  model                 ReportDataModel          @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([status])
  @@index([deletedAt])
}

model ReportModelRelation {
  id                    Int                      @id @default(autoincrement())
  modelId               Int
  relationCode          String
  relationName          String
  description           String?
  relationType          String
  targetModel           String
  joinCondition         String?
  config                String                   @default("{}")
  status                String                   @default("ACTIVE")
  sortOrder             Int                      @default(0)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  deletedAt             DateTime?
  model                 ReportDataModel          @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@index([status])
  @@index([deletedAt])
}
