// ============ Workflow 模块相关模型 ============

model WorkflowDefinition {
  id                Int                  @id @default(autoincrement())
  code              String
  name              String
  description       String?
  category          String               @default("GENERAL")
  version           Int                  @default(1)
  versionString     String               @default("1")
  status            String               @default("DRAFT")
  formConfig        String               @default("{}")
  flowConfig        String               @default("{}")
  isSystem          Boolean              @default(false)
  publishedAt       DateTime?
  createdById       Int
  createdByName     String
  updatedById       Int?
  updatedByName     String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  nodes             WorkflowNode[]
  edges             WorkflowEdge[]
  instances         WorkflowInstance[]

  @@unique([code, version])
  @@index([status])
  @@index([category])
  @@index([code])
  @@index([deletedAt])
}

model WorkflowNode {
  id                Int                  @id @default(autoincrement())
  workflowId        Int
  nodeCode          String               @unique
  nodeType          String
  nodeName          String
  needAllApprove    Boolean              @default(false)
  approverStrategy  String?
  approverConfig    String?
  ccStrategy        String?
  conditionConfig   String?
  formPermission    String?
  sortOrder         Int                  @default(0)
  status            String               @default("ACTIVE")
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  definition        WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  outgoingEdges     WorkflowEdge[]       @relation("OutgoingEdges")
  incomingEdges     WorkflowEdge[]       @relation("IncomingEdges")

  @@index([workflowId])
  @@index([nodeCode])
}

model WorkflowEdge {
  id                Int                  @id @default(autoincrement())
  workflowId        Int
  sourceNodeId      Int
  targetNodeId      Int
  condition         String?
  label             String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  definition        WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  sourceNode        WorkflowNode         @relation("IncomingEdges", fields: [sourceNodeId], references: [id])
  targetNode        WorkflowNode         @relation("OutgoingEdges", fields: [targetNodeId], references: [id])

  @@index([workflowId])
  @@index([sourceNodeId])
  @@index([targetNodeId])
}

model WorkflowInstance {
  id                Int                  @id @default(autoincrement())
  workflowId        Int
  instanceNo        String               @unique
  title             String
  category          String
  status            String               @default("RUNNING")
  initiatorId       Int
  initiatorName     String
  initiatorOrgId    Int
  initiatorOrgName  String
  currentStep       String?
  data              String               @default("{}")
  initiatedAt       DateTime             @default(now())
  startTime         DateTime             @default(now())
  finishedAt        DateTime?
  endTime           DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  definition        WorkflowDefinition  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  approvals         WorkflowApproval[]
  supportRequests   SupportRequest[]
  laborHourReports  LaborHourReportRequest[]
  ccRecords         WorkflowCcRecord[]

  @@index([workflowId])
  @@index([instanceNo])
  @@index([status])
  @@index([deletedAt])
}

model WorkflowApproval {
  id                Int                  @id @default(autoincrement())
  instanceId        Int
  instanceNo        String
  nodeId            Int
  nodeCode          String
  nodeName          String
  step              String
  approverId        Int
  approverName      String
  approvers         String               @default("[]")
  needAllApprove    Boolean              @default(false)
  action            String               @default("")
  status            String               @default("PENDING")
  comment           String?
