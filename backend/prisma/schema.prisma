  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  instance          WorkflowInstance    @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@index([instanceId])
  @@index([approverId])
  @@index([status])
}

model WorkflowParticipant {
